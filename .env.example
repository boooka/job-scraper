# Database
DATABASE_URL=postgresql+asyncpg://scraper:scraper_pass@localhost:5432/job_scraper
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Scraper settings
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
SCRAPER_SLOW_MO_MS=500
SCRAPER_CONCURRENCY=2

# Scheduler (cron expressions)
SCHEDULE_CVBANKAS=0 */4 * * *
SCHEDULE_CVONLINE=30 */4 * * *
SCHEDULE_CVMARKET=0 1 * * *
SCHEDULE_CV=0 1 * * *
SCHEDULE_TRANSLATIONS=*/15 * * * *
SCHEDULE_SUBSCRIPTION_NOTIFICATIONS=*/10 * * * *

# Retry settings
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_SECONDS=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# DeepL
DEEPL_API_KEY=your_deepl_api_key
DEEPL_TARGET_LANG=RU
DEEPL_BATCH_SIZE=50
DEEPL_DELAY_MS=200
DEEPL_BATCH_CHAR_QUOTA=10000

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USERNAMES=admin_username,another_admin
TELEGRAM_POLL_TIMEOUT_SECONDS=20
TELEGRAM_SEARCH_LIMIT=20
TELEGRAM_API_MAX_RETRIES=5
TELEGRAM_API_BACKOFF_BASE_SECONDS=0.5
TELEGRAM_API_BACKOFF_JITTER_SECONDS=0.25
TELEGRAM_REGEX_MAX_LENGTH=120
TELEGRAM_REGEX_MAX_GROUPS=10
TELEGRAM_REGEX_MAX_ALTERNATIONS=12
TELEGRAM_SEARCH_SHOW_ALL_THRESHOLD=3
TELEGRAM_SEARCH_NEXT_BATCH_SIZE=5
METRICS_TOP_SEARCH_QUERIES=10
METRICS_DUMP_PATH=logs/metrics/metrics.jsonl
METRICS_DUMP_INTERVAL_SECONDS=300
TELEGRAM_DEBUG_LOGGING=true
TELEGRAM_DEBUG_LOG_PATH=logs/telegram/debug.log
APP_LOG_PATH=logs/app/app.log
SCRAPER_LOG_PATH=logs/scraper/scraper.log