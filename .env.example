# Database
DATABASE_URL=postgresql+asyncpg://scraper:scraper_pass@localhost:5432/job_scraper
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Postgres container credentials.
# In dev (docker-compose.yml) these have hardcoded defaults and are optional.
# In prod (docker-compose.prod.yml) POSTGRES_PASSWORD is REQUIRED — the DATABASE_URL
# used by the app is assembled from these three vars (host: postgres), so set a
# strong password here and it stays in sync across the DB and all services.
POSTGRES_USER=scraper
POSTGRES_PASSWORD=scraper_pass
POSTGRES_DB=job_scraper

# Scraper settings
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
SCRAPER_SLOW_MO_MS=500
SCRAPER_CONCURRENCY=2

# Scheduler (cron expressions)
SCHEDULE_CVBANKAS=0 */4 * * *
SCHEDULE_CVONLINE=30 */4 * * *
SCHEDULE_CVMARKET=0 1 * * *
SCHEDULE_CV=0 1 * * *
SCHEDULE_TRANSLATIONS=*/15 * * * *
SCHEDULE_SUBSCRIPTION_NOTIFICATIONS=*/10 * * * *
SCHEDULE_DAILY_REPORT=0 9 * * *

# Admin notifications
ADMIN_NOTIFY_NEW_USERS=true
ADMIN_NOTIFY_NEW_SUBSCRIPTIONS=true
DAILY_REPORT_STALE_HOURS=24

# Retry settings
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_SECONDS=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# DeepL — один или несколько ключей через запятую. Клиент ротирует ключи при
# исчерпании квоты (HTTP 456); переводы отключаются только когда исчерпаны ВСЕ.
# Free-ключи оканчиваются на ":fx", Pro — нет.
# Пример нескольких: DEEPL_API_KEY=key1:fx,key2:fx
DEEPL_API_KEY=your_deepl_api_key
DEEPL_TARGET_LANG=RU
DEEPL_BATCH_SIZE=50
DEEPL_DELAY_MS=200
DEEPL_BATCH_CHAR_QUOTA=10000

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USERNAMES=admin_username,another_admin
TELEGRAM_POLL_TIMEOUT_SECONDS=20
TELEGRAM_SEARCH_LIMIT=20
TELEGRAM_API_MAX_RETRIES=5
TELEGRAM_API_BACKOFF_BASE_SECONDS=0.5
TELEGRAM_API_BACKOFF_JITTER_SECONDS=0.25
TELEGRAM_REGEX_MAX_LENGTH=120
TELEGRAM_REGEX_MAX_GROUPS=10
TELEGRAM_REGEX_MAX_ALTERNATIONS=12
TELEGRAM_SEARCH_SHOW_ALL_THRESHOLD=3
TELEGRAM_SEARCH_NEXT_BATCH_SIZE=5
METRICS_TOP_SEARCH_QUERIES=10
METRICS_DUMP_PATH=logs/metrics/metrics.jsonl
METRICS_DUMP_INTERVAL_SECONDS=300
TELEGRAM_DEBUG_LOGGING=true
TELEGRAM_DEBUG_LOG_PATH=logs/telegram/debug.log
APP_LOG_PATH=logs/app/app.log
SCRAPER_LOG_PATH=logs/scraper/scraper.log

# Django admin panel
DJANGO_SECRET_KEY=change-me-to-a-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*
# Секретный путь админки вместо /admin (защита от сканеров). Открывается по
# https://<домен>/<этот-путь>/. Задайте длинную случайную строку без /.
# /admin и корень будут отдавать 404.
DJANGO_ADMIN_PATH=change-me-to-a-secret-path

# HTTP Basic Auth в Caddy перед админкой (второй фактор поверх Django-логина).
# Сгенерировать хеш:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'ваш-пароль'
# Хеш содержит '$' — в .env оставляйте как есть (env_file не интерполирует).
ADMIN_BASIC_USER=admin
ADMIN_BASIC_HASH=
# Домен админки за Caddy (prod). Нужна A-запись домена на IP сервера и открытые
# порты 80/443. Caddy сам выпустит Let's Encrypt-сертификат. ALLOWED_HOSTS и
# CSRF_TRUSTED_ORIGINS для prod собираются из него в docker-compose.prod.yml.
ADMIN_DOMAIN=joblt.bo0.me